{
  "manifest_version": 3,
  "name": "todox 북마크",
  "description": "아이콘 클릭으로 현재 탭을 북마크에 추가하고, 메뉴에서 목록을 봅니다.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "activeTab", "contextMenus", "notifications"],
  "host_permissions": [
    "http://localhost:57327/*",
    "http://127.0.0.1:57327/*",
    "https://*.github.io/todox/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "bookmarks.html",
  "content_scripts": [
    {
      "matches": ["http://localhost:57327/*", "http://127.0.0.1:57327/*", "https://*.github.io/todox/*"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "클릭: 북마크 추가"
  }
}

